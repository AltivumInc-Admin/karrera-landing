# AWS Region (defaults to us-east-1)
NEXT_PUBLIC_AWS_REGION=us-east-1

# Cognito User Pool
NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_zp5vUWnd5
NEXT_PUBLIC_COGNITO_CLIENT_ID=7fnsnujmgili0k5lai9qm97cmr

# S3 Resume Bucket (optional override — defaults to karrera-resumes-prod)
# NEXT_PUBLIC_S3_RESUME_BUCKET=karrera-resumes-prod

# AWS credentials are NOT needed on Amplify (IAM role provides them).
# For local development, use ~/.aws/credentials or set standard AWS env vars:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
